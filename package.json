{
  "name": "xlayer-agent-nexus",
  "version": "1.0.0",
  "description": "X Layer Agent Marketplace - Autonomous Agent-to-Agent Service Market",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network xlayer",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network xlayer_testnet",
    "test": "node --test tests/*.test.cjs",
    "test:contract": "npx hardhat test",
    "demo": "node src/demo.js",
    "agent:run": "node src/agents/orchestrator.js"
  },
  "keywords": ["xlayer", "agent", "marketplace", "okx", "onchainos", "uniswap", "hackathon"],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.13.0",
    "dotenv": "^16.4.5",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0"
  }
}
